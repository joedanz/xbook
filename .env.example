# xbook — Environment Variables
#
# Docker:    cp .env.example .env
# Local dev: cp .env.example .env.local

# --- Required ---

# X (Twitter) API credentials — get from https://developer.x.com
X_CLIENT_ID=
X_CLIENT_SECRET=

# --- Optional ---

# Resend API key for newsletter emails
# RESEND_API_KEY=re_xxxxx

# Newsletter recipient email
# NEWSLETTER_TO=you@example.com

# Database file path (default: ./xbook.db, or /data/xbook.db in Docker)
# DB_PATH=./xbook.db

# OAuth redirect URI (X rejects "localhost" — use 127.0.0.1 for local dev)
# OAUTH_REDIRECT_URI=http://127.0.0.1:3000/api/connect-x/callback
