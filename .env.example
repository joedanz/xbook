# =============================================================================
# xbook Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values.

# --- X (Twitter) API Credentials ---
# Required for bookmark syncing. Get these from https://developer.x.com
X_CLIENT_ID=
X_CLIENT_SECRET=

# --- Newsletter (Optional) ---
# Resend API key for sending newsletter emails. Get one at https://resend.com
# RESEND_API_KEY=

# Newsletter recipient email
# NEWSLETTER_TO=you@example.com

# Newsletter sender email (must be from a domain verified in Resend)
# NEWSLETTER_FROM=bookmarks@yourdomain.com

# --- Database ---
# Path to SQLite database (default: ../xbook.db or /data/xbook.db in Docker)
# DB_PATH=./xbook.db

# --- OAuth ---
# Path to OAuth token file (default: .tokens.json)
# TOKEN_FILE_PATH=./.tokens.json
