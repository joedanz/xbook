# xbook — Environment Variables
# Copy this file to .env.local and fill in the values.

# --- Required for local development ---

# X (Twitter) API credentials — get from https://developer.x.com
X_CLIENT_ID=
X_CLIENT_SECRET=

# --- Optional ---

# Resend API key for newsletter emails
# RESEND_API_KEY=re_xxxxx

# Newsletter recipient
# NEWSLETTER_TO=you@example.com

# Database file path (default: ./xbook.db)
# DB_PATH=./xbook.db

# OAuth redirect URI for web (X rejects "localhost" — use 127.0.0.1)
# OAUTH_REDIRECT_URI=http://127.0.0.1:3000/api/connect-x/callback
